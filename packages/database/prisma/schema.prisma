datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}







model Organization {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  logoUrl       String?
  customDomain  String?        @unique
  billingPlan   String         @default("FREE")
  createdAt     DateTime       @default(now())
  
  users         UserOrgLink[]
  campuses      Campus[]
}

model Campus {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departments    Department[]
}

model Department {
  id        String   @id @default(cuid())
  campusId  String
  name      String

  campus    Campus   @relation(fields: [campusId], references: [id], onDelete: Cascade)
  classes   Class[]
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  password      String?
  role          String            @default("STUDENT")
  language      String          @default("en")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  orgs          UserOrgLink[]
  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  parentProfile  ParentProfile?
  developerProfile DeveloperProfile?

  aiMemory      AIMemory?
  notifications Notification[]
  sentMessages  Message[]       @relation("SentMessages")
  recvMessages  Message[]       @relation("ReceivedMessages")
  auditLogs     AuditLog[]
  apiKeys       ApiKey[]
}

model UserOrgLink {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  roleInOrg      String         @default("STUDENT")

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model DeveloperProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  companyName  String?
  verified     Boolean  @default(false)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings     MarketplaceListing[]
}

model TeacherProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  bio        String?
  approved   Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  classes    Class[]
  quizzes    Quiz[]
  notebooks  AINotebook[]
  courses    Course[]
  questions  QuestionBank[]
  workflows  Workflow[]
}

model StudentProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  xp            Int      @default(0)
  level         Int      @default(1)
  coins         Int      @default(0)
  streak        Int      @default(0)
  lastActive    DateTime?
  avatarId      String?
  frameId       String?
  themeId       String?
  petId         String?
  guildId       String?
  parentId      String?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild         Guild?         @relation(fields: [guildId], references: [id], onDelete: SetNull)
  parent        ParentProfile? @relation(fields: [parentId], references: [id], onDelete: SetNull)

  enrollments   ClassEnrollment[]
  quizAttempts  QuizAttempt[]
  submissions   AssignmentSubmission[]
  attendance    Attendance[]
  notebooks     AINotebook[]
  achievements  EarnedAchievement[]
  certificates  Certificate[]
  userQuests    UserQuest[]
  bookmarks     Bookmark[]
  inventory     InventoryItem[]
  courseProgress CourseProgress[]
  friends       Friendship[]   @relation("StudentFriends")
  friendOf      Friendship[]   @relation("FriendOfStudent")
}

model ParentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  students  StudentProfile[]
}

model Guild {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  totalXp     Int      @default(0)
  students    StudentProfile[]
}

model Friendship {
  id          String   @id @default(cuid())
  studentId   String
  friendId    String
  accepted    Boolean  @default(false)
  createdAt   DateTime @default(now())

  student     StudentProfile @relation("StudentFriends", fields: [studentId], references: [id], onDelete: Cascade)
  friend      StudentProfile @relation("FriendOfStudent", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([studentId, friendId])
}

model AIMemory {
  id              String   @id @default(cuid())
  userId          String   @unique
  learningStyle   String   @default("visual")
  readingLevel    Int      @default(5)
  attentionSpan   Int      @default(15)
  weakTopics      String   @default("[]")
  strongTopics    String   @default("[]")
  preferredLanguage String @default("en")
  mistakeLog      String   
  lastUpdated     DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Class {
  id            String   @id @default(cuid())
  departmentId  String?
  name          String
  description   String?
  code          String   @unique
  teacherId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  department    Department?       @relation(fields: [departmentId], references: [id])
  teacher       TeacherProfile    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments   ClassEnrollment[]
  assignments   Assignment[]
  announcements Announcement[]
  attendance    Attendance[]
  messages      Message[]
  courses       Course[]
}

model ClassEnrollment {
  id        String   @id @default(cuid())
  studentId String
  classId   String
  joinedAt  DateTime @default(now())

  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class     Class          @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId])
}

model Announcement {
  id        String   @id @default(cuid())
  classId   String
  title     String
  content   String   
  createdAt DateTime @default(now())

  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
}

model Course {
  id          String   @id @default(cuid())
  classId     String?
  teacherId   String
  title       String
  description String?  
  published   Boolean  @default(false)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class       Class?          @relation(fields: [classId], references: [id])
  teacher     TeacherProfile  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  modules     CourseModule[]
  bookmarks   Bookmark[]
  progress    CourseProgress[]
  versions    VersionHistory[] @relation("CourseVersions")
}

model CourseModule {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
}

model Lesson {
  id            String   @id @default(cuid())
  moduleId      String
  title         String
  content       String   
  videoUrl      String?
  videoChapters String?
  audioUrl      String?
  order         Int

  module        CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quizzes       Quiz[]
  assignments   Assignment[]
  bookmarks     Bookmark[]
}

model Assignment {
  id          String   @id @default(cuid())
  classId     String?
  lessonId    String?
  title       String
  description String   
  rubric      String?  
  dueDate     DateTime
  points      Int      @default(100)
  createdAt   DateTime @default(now())

  class       Class?                 @relation(fields: [classId], references: [id], onDelete: Cascade)
  lesson      Lesson?                @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  submissions AssignmentSubmission[]
  files       FileAttachment[]
}

model AssignmentSubmission {
  id              String   @id @default(cuid())
  assignmentId    String
  studentId       String
  submittedAt     DateTime @default(now())
  grade           Float?
  feedback        String?  
  plagiarismScore Float?
  grammarFlags    String?  

  assignment      Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student         StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  files           FileAttachment[]
}

model CourseProgress {
  id          String   @id @default(cuid())
  studentId   String
  courseId    String
  completedLessons String @default("[]")
  completedQuizzes String @default("[]")
  updatedAt   DateTime @updatedAt

  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course      Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
}

model Attendance {
  id        String           @id @default(cuid())
  classId   String
  studentId String
  date      DateTime
  status    String // PRESENT, ABSENT, LATE (as String to support custom database enums)

  class     Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId, date])
}

model Quiz {
  id               String   @id @default(cuid())
  teacherId        String
  lessonId         String?
  title            String
  description      String?
  code             String?  @unique
  isLive           Boolean  @default(false)
  timeLimit        Int      @default(30)
  version          Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  teacher          TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  lesson           Lesson?        @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  questions        Question[]
  attempts         QuizAttempt[]
  versions         VersionHistory[] @relation("QuizVersions")
}

model Question {
  id               String       @id @default(cuid())
  quizId           String
  type             String
  text             String       
  mediaUrl         String?
  timeLimit        Int          @default(30)
  points           Int          @default(1000)
  answerExplanation String?     
  hints            String @default("[]")
  order            Int

  quiz             Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options          AnswerOption[]
  responses        QuestionResponse[]
}

model AnswerOption {
  id         String   @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  order      Int

  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  responses  QuestionResponse[]
}

model QuestionBank {
  id               String       @id @default(cuid())
  teacherId        String
  type             String
  text             String       
  mediaUrl         String?
  timeLimit        Int          @default(30)
  answerExplanation String?     
  tags             String @default("[]")
  favorite         Boolean      @default(false)

  teacher          TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id          String   @id @default(cuid())
  quizId      String
  studentId   String
  score       Int      @default(0)
  timeSpent   Int      @default(0)
  completedAt DateTime @default(now())

  quiz        Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student     StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  responses   QuestionResponse[]
}

model QuestionResponse {
  id               String   @id @default(cuid())
  attemptId        String
  questionId       String
  selectedOptionId String?
  textAnswer       String?
  isCorrect        Boolean  @default(false)
  pointsEarned     Int      @default(0)
  timeSpent        Int      @default(0)

  attempt          QuizAttempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question         Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption   AnswerOption? @relation(fields: [selectedOptionId], references: [id])
}

model AINotebook {
  id          String   @id @default(cuid())
  teacherId   String?
  studentId   String?
  name        String
  description String?
  createdAt   DateTime @default(now())

  teacher     TeacherProfile? @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student     StudentProfile? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  documents   Document[]
  chats       AIChat[]
  flashcards  Flashcard[]
  canvasNodes CanvasNode[]
}

model Document {
  id          String   @id @default(cuid())
  notebookId  String
  title       String
  fileUrl     String
  fileType    String
  content     String   
  summary     String?  
  createdAt   DateTime @default(now())

  notebook    AINotebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
}

model AIChat {
  id          String   @id @default(cuid())
  notebookId  String
  role        String
  content     String   
  createdAt   DateTime @default(now())

  notebook    AINotebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
}

model Flashcard {
  id              String   @id @default(cuid())
  notebookId      String
  front           String   
  back            String   
  interval        Int      @default(1)
  repetitionCount Int      @default(0)
  easeFactor      Float    @default(2.5)
  nextReviewDate  DateTime @default(now())
  createdAt       DateTime @default(now())

  notebook        AINotebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
}

model CanvasNode {
  id          String     @id @default(cuid())
  notebookId  String
  type        String
  x           Float
  y           Float
  width       Float      @default(200)
  height      Float      @default(150)
  content     String?    
  style       String?

  notebook    AINotebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
}

model FileAttachment {
  id           String   @id @default(cuid())
  name         String
  url          String
  type         String
  size         Int
  assignmentId String?
  submissionId String?
  createdAt    DateTime @default(now())

  assignment   Assignment?           @relation(fields: [assignmentId], references: [id])
  submission   AssignmentSubmission? @relation(fields: [submissionId], references: [id])
}

model VersionHistory {
  id          String   @id @default(cuid())
  courseId    String?
  quizId      String?
  versionNum  Int
  snapshot    String   
  changedBy   String
  createdAt   DateTime @default(now())

  course      Course?  @relation("CourseVersions", fields: [courseId], references: [id], onDelete: Cascade)
  quiz        Quiz?    @relation("QuizVersions", fields: [quizId], references: [id], onDelete: Cascade)
}

model Quest {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String
  xpReward    Int
  coinReward  Int
  targetCount Int
  actionType  String

  userQuests  UserQuest[]
}

model UserQuest {
  id          String   @id @default(cuid())
  studentId   String
  questId     String
  progress    Int      @default(0)
  completed   Boolean  @default(false)

  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  quest       Quest          @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([studentId, questId])
}

model ShopItem {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Int
  type        String
  imageUrl    String
  styleConfig String?

  purchasedBy InventoryItem[]
}

model InventoryItem {
  id          String   @id @default(cuid())
  studentId   String
  itemId      String
  equipped    Boolean  @default(false)
  purchasedAt DateTime @default(now())

  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  item        ShopItem       @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([studentId, itemId])
}

model Achievement {
  id          String   @id @default(cuid())
  title       String
  description String
  badgeUrl    String
  xpReward    Int      @default(100)
  coinReward  Int      @default(50)

  earnedBy    EarnedAchievement[]
}

model EarnedAchievement {
  id            String   @id @default(cuid())
  studentId     String
  achievementId String
  earnedAt      DateTime @default(now())

  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  achievement   Achievement    @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([studentId, achievementId])
}

model Certificate {
  id          String   @id @default(cuid())
  studentId   String
  title       String
  description String
  pdfUrl      String
  qrCode      String?
  issuedAt    DateTime @default(now())

  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Workflow {
  id          String   @id @default(cuid())
  teacherId   String
  name        String
  triggerEvent String
  actionsJson String   
  active      Boolean  @default(true)

  teacher     TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model MarketplaceListing {
  id          String   @id @default(cuid())
  developerId String?
  title       String
  description String
  type        String
  price       Int      @default(0)
  assetUrl    String?
  metadata    String?  
  downloads   Int      @default(0)
  rating      Float    @default(5.0)
  createdAt   DateTime @default(now())

  developer   DeveloperProfile? @relation(fields: [developerId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  ipAddress   String?
  details     String?  
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  keyHash     String   @unique
  name        String
  scopes      String @default("[]")
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id          String   @id @default(cuid())
  classId     String?
  senderId    String
  receiverId  String?
  content     String   
  createdAt   DateTime @default(now())

  class       Class?   @relation(fields: [classId], references: [id], onDelete: Cascade)
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User?    @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: SetNull)
}

model Bookmark {
  id          String   @id @default(cuid())
  studentId   String
  courseId    String?
  lessonId    String?
  createdAt   DateTime @default(now())

  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course      Course?        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson      Lesson?        @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId, lessonId])
}
