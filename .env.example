# Database connection URL (PostgreSQL via Neon, Supabase, or Local Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/learningma?schema=public"

# NextAuth Authentication Config
# Generate a secret: openssl rand -base64 33
AUTH_SECRET="your-auth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google Gemini API Key for AI Multi-Agent & RAG Copilot
GEMINI_API_KEY="your-gemini-api-key-here"

# UploadThing configuration for cloud storage (optional in dev, fallback is local)
UPLOADTHING_SECRET="your-uploadthing-secret"
UPLOADTHING_APP_ID="your-uploadthing-app-id"
